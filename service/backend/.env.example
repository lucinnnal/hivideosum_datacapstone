# ---------- YouTube collection (optional proxy) ----------
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Or generic proxy:
# TRANSCRIPT_HTTP_PROXY=
# TRANSCRIPT_HTTPS_PROXY=

# ---------- HuggingFace (vLLM 모델 다운로드) ----------
# Gemma 등 gated 모델 사용 시 필수. https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=

# ---------- Vertex AI Gemini (filter step) ----------
GOOGLE_GENAI_USE_VERTEXAI=True
GCP_PROJECT=hivideosum
GCP_LOCATION=global
# 로컬 개발: gcloud auth application-default login 후 아래 경로 지정 (해줘야 함)
GOOGLE_SA_PATH=/home/$USER/.config/gcloud/application_default_credentials.json
# Docker / 운영: 서비스 계정 JSON 경로 지정
# GOOGLE_SA_PATH=/absolute/path/to/sa.json

# ---------- vLLM (summary step) ----------
VLLM_BASE_URL=http://vllm:8001/v1
VLLM_MODEL_NAME=hivideosum
VLLM_API_KEY=dummy

# ---------- Infra ----------
REDIS_URL=redis://redis:6379/0

# ---------- API behavior ----------
API_HOST=0.0.0.0
API_PORT=8000
RESULT_TTL_SECONDS=86400
COLLECT_MAX_REGULAR=50
COLLECT_MAX_TIMESTAMP=50

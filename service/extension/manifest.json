{
  "manifest_version": 3,
  "name": "Hi-VideoSum",
  "version": "0.1.0",
  "description": "YouTube 영상을 자막·댓글 기반으로 3문단 요약해주는 확장 프로그램.",

  "permissions": ["storage"],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*", "*://m.youtube.com/watch*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  },

  "action": {
    "default_title": "Hi-VideoSum 옵션 열기",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
